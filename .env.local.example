# ════════════════════════════════════════════════════════════════════
# Wiltek Portal V2 — local migration script env
#
# COPY this file to `.env.local` (already gitignored), paste the real
# keys from Supabase dashboard → Settings → API, then run:
#
#   npm install
#   node tools/migrate-supabase.mjs items
#
# `.env.local` is loaded by tools/migrate-supabase.mjs via dotenv.
# NEVER commit `.env.local` — it contains the service role key, which
# bypasses RLS and can read/write the entire database.
# ════════════════════════════════════════════════════════════════════

# Supabase project URL (safe to share)
WILTEK_SUPABASE_URL=https://hredgxwqqfkfqtkaotlg.supabase.co

# Anon / publishable key (safe to ship in browser bundles).
# Found at: Supabase dashboard → Settings → API → "anon" or "publishable"
WILTEK_SUPABASE_ANON_KEY=paste_anon_key_here

# Service role key — SERVER-SIDE ONLY. Bypasses RLS.
# Found at: Supabase dashboard → Settings → API → "service_role" (click "reveal")
# This is what tools/migrate-supabase.mjs uses to bulk-insert past RLS.
WILTEK_SUPABASE_SERVICE_ROLE_KEY=paste_service_role_key_here
