{
  "name": "wiltek-portal-qa",
  "version": "1.0.0",
  "private": true,
  "description": "Wiltek Executive Portal — QA test harness (Playwright). Static site lives at root; this package exists only for the test suite.",
  "scripts": {
    "serve": "node tests/serve.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:i18n": "node tools/i18n_audit.js --count && node tools/i18n_check.js --ci",
    "test:i18n:runtime": "node tools/i18n_runtime_check.js",
    "test:rbac": "node tools/rbac_test.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^17.4.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3"
  }
}
